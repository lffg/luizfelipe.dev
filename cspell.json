{
  "enabledLanguageIds": ["*"],
  "languageSettings": [
    {
      "languageId": "*",
      "locale": "*",
      "caseSensitive": false
    }
  ],
  "import": [
    "@cspell/dict-pt-br/cspell-ext.json",
    "@cspell/dict-pt-pt/cspell-ext.json"
  ],
  "dictionaries": ["pt-br", "pt-pt"],
  "ignorePaths": [".git"],
  "useGitignore": true,
  "words": [
    "generi",
    "Iosevka",
    "lffg",
    "luizfelipe",
    "middot",
    "noopener",
    "noreferrer",
    "pnpm",
    "println",
    "struct",
    "tsbuildinfo",
    "vercel"
  ]
}
